{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.raymondchins/agentmap",
  "description": "TS/JS-accurate repo map for coding agents: a ts-morph import/symbol graph, 8 MCP query tools.",
  "repository": {
    "url": "https://github.com/raymondchins/agentmap",
    "source": "github"
  },
  "version": "0.12.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@raymondchins/agentmap",
      "version": "0.12.2",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "named",
          "name": "--mcp"
        }
      ]
    }
  ]
}
