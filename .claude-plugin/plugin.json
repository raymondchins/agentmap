{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "agentmap",
  "displayName": "agentmap",
  "version": "0.13.1",
  "description": "The repo map your coding agent is forced to use — a queryable, PageRank-ranked ts-morph import/symbol map for TS/JS repos. Bundles the PreToolUse grep nudge, the navigation skill, and a stdio MCP server exposing 8 query tools.",
  "author": {
    "name": "Raymond Surya Chin"
  },
  "homepage": "https://github.com/raymondchins/agentmap#readme",
  "repository": "https://github.com/raymondchins/agentmap",
  "license": "MIT",
  "keywords": ["agentmap", "repo-map", "ts-morph", "typescript", "pagerank", "code-graph", "context"],
  "skills": ["./skills"],
  "hooks": "./hooks/hooks.json",
  "mcpServers": {
    "agentmap": {
      "command": "npx",
      "args": ["-y", "@raymondchins/agentmap", "--mcp"]
    }
  }
}
